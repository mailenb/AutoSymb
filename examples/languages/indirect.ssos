indirect specification {
    syntax {
        program-syntax {
            p : a # Ref | 'a' # Term ;
            a : p # Illegal ;
        }

        variable-syntax {
            x : /[a-zA-Z][a-zA-Z0-9_']*/ # Id;
        }
    }

    semantics {
        rule a [Term] {
            conclusion { (a, a1) => (end, a1) }
        }
    }
}
